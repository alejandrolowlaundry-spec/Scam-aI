# ─────────────────────────────────────────────────────────────────
#  Fraud Detection Agent — Environment Variables
# ─────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your keys.
#  Set DEMO_MODE=true to run the full system with NO real API calls.
# ─────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
FRONTEND_URL=http://localhost:5173
DEMO_MODE=true          # ← flip to false when you add real keys

# ── Database ──────────────────────────────────────────────────────
# SQLite (default — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./fraud_detection.db
# PostgreSQL (Railway / Render — uncomment and use asyncpg driver)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/fraud_db

# ── HubSpot ───────────────────────────────────────────────────────
# Create a Private App: HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.deals.read  crm.objects.deals.write
#                  crm.objects.contacts.read  crm.objects.notes.write
HUBSPOT_API_KEY=pat-na1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Twilio ────────────────────────────────────────────────────────
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567    # Your Twilio number (E.164)

# ── ElevenLabs ────────────────────────────────────────────────────
# elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides (defaults work well out of the box)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel
# ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# ── Claude / Anthropic ────────────────────────────────────────────
# console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CLAUDE_MODEL=claude-sonnet-4-5     # default — change to claude-sonnet-4-6 for latest

# ── Transcription — AssemblyAI ────────────────────────────────────
# assemblyai.com → Get API Key (free tier available)
ASSEMBLYAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Alerts ────────────────────────────────────────────────────────
# SendGrid: app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourcompany.com
ALERT_TO_EMAIL=security@yourcompany.com
ALERT_TO_PHONE=+15559876543     # SMS recipient (E.164 format)

# ── Risk Thresholds ───────────────────────────────────────────────
HIGH_RISK_THRESHOLD=70           # ≥ 70  → Confirmed Scam  → "Scam / Fraud"
MEDIUM_RISK_THRESHOLD=40         # ≥ 40  → Suspicious      → "Needs Manual Review"
                                 # < 40  → Safe Customer   → "Verified Customer"
